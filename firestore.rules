rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Contact form messages - allow create only, no read/update/delete from client
    match /mensajes/{messageId} {
      allow create: if request.resource.data.keys().hasOnly(['texto', 'fechaEnvio', 'email'])
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() > 0
                    && request.resource.data.texto.size() <= 500
                    && request.resource.data.fechaEnvio is string
                    && (!request.resource.data.keys().hasAny(['email'])
                        || (request.resource.data.email is string
                            && request.resource.data.email.size() <= 254));
      allow read, update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
